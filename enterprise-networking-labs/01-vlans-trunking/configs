/ON SWITCH A

! VLANs
vlan 10
 name Admin
vlan 20
 name Accounts
vlan 30
 name HR
vlan 40
 name Voice
vlan 99
 name Management
vlan 100
 name Native

! Management VLAN
interface vlan 99
 ip address 192.168.99.252 255.255.255.0
 no shutdown

! Trunk to SWB (Static)
interface g0/1
 switchport mode trunk
 switchport trunk native vlan 100
 switchport nonegotiate

! Trunk to SWC (Dynamic)
interface g0/2
 switchport mode dynamic desirable
 switchport trunk native vlan 100
